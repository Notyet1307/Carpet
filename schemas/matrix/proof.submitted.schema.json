{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/matrix/proof.submitted.schema.json",
  "title": "Matrix Proof Submitted Event",
  "allOf": [
    {
      "$ref": "https://notyet.dev/schemas/matrix/event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["task_id", "run_id", "trace_id", "actor", "data"],
      "properties": {
        "type": {
          "const": "com.notyet.agent.proof.submitted"
        },
        "subject": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "task_id": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "run_id": {
          "type": "string",
          "pattern": "^run_[A-Za-z0-9_-]+$"
        },
        "trace_id": {
          "type": "string",
          "pattern": "^trace_[A-Za-z0-9_-]+$"
        },
        "actor": {
          "type": "object",
          "properties": {
            "type": {
              "const": "runtime"
            }
          }
        },
        "data": {
          "type": "object",
          "required": ["proof_id"],
          "properties": {
            "proof_id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^proof_[A-Za-z0-9_-]+$"
            },
            "artifact_refs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["kind", "uri", "sha256"],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": ["patch", "log", "report", "schema", "fixture"]
                  },
                  "uri": {
                    "type": "string",
                    "format": "uri"
                  },
                  "sha256": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                  }
                },
                "additionalProperties": false
              }
            },
            "validation_summary": {
              "type": "object",
              "required": ["status", "command_count"],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["passed", "failed", "skipped"]
                },
                "command_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "passed_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "failed_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "summary": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
