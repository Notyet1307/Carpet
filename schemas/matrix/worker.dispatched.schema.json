{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/matrix/worker.dispatched.schema.json",
  "title": "Matrix Worker Dispatched Event",
  "allOf": [
    {
      "$ref": "https://notyet.dev/schemas/matrix/event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["task_id", "run_id", "trace_id", "actor", "data"],
      "properties": {
        "type": {
          "const": "com.notyet.agent.worker.dispatched"
        },
        "subject": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "task_id": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "run_id": {
          "type": "string",
          "pattern": "^run_[A-Za-z0-9_-]+$"
        },
        "trace_id": {
          "type": "string",
          "pattern": "^trace_[A-Za-z0-9_-]+$"
        },
        "actor": {
          "type": "object",
          "properties": {
            "type": {
              "const": "runtime"
            }
          }
        },
        "data": {
          "type": "object",
          "required": [
            "worker_id",
            "capability_id",
            "worktree_path",
            "branch",
            "base_sha"
          ],
          "properties": {
            "worker_id": {
              "type": "string",
              "pattern": "^worker_[A-Za-z0-9_-]+$"
            },
            "capability_id": {
              "type": "string",
              "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)*$"
            },
            "worktree_path": {
              "type": "string",
              "pattern": "^\\.\\./\\.worktrees/[A-Za-z0-9][A-Za-z0-9_.-]*/[A-Za-z0-9][A-Za-z0-9_.-]*$"
            },
            "branch": {
              "type": "string",
              "minLength": 1
            },
            "base_sha": {
              "type": "string",
              "pattern": "^[a-f0-9]{7,40}$"
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
