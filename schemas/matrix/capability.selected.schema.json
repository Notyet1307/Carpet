{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/matrix/capability.selected.schema.json",
  "title": "Matrix Capability Selected Event",
  "allOf": [
    {
      "$ref": "https://notyet.dev/schemas/matrix/event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["task_id", "trace_id", "actor", "data"],
      "properties": {
        "type": {
          "const": "com.notyet.agent.capability.selected"
        },
        "subject": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "task_id": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "trace_id": {
          "type": "string",
          "pattern": "^trace_[A-Za-z0-9_-]+$"
        },
        "actor": {
          "type": "object",
          "properties": {
            "type": {
              "const": "runtime"
            }
          }
        },
        "data": {
          "type": "object",
          "required": [
            "task_id",
            "capability_id",
            "capability_version",
            "selection_reason"
          ],
          "properties": {
            "task_id": {
              "type": "string",
              "pattern": "^task_[A-Za-z0-9_-]+$"
            },
            "capability_id": {
              "type": "string",
              "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)*$"
            },
            "capability_version": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
            },
            "selection_reason": {
              "type": "string",
              "minLength": 1
            },
            "policy_decision_id": {
              "type": "string",
              "pattern": "^policy_decision_[A-Za-z0-9_-]+$"
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
