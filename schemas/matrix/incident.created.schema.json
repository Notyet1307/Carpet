{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/matrix/incident.created.schema.json",
  "title": "Matrix Incident Created Event",
  "allOf": [
    {
      "$ref": "https://notyet.dev/schemas/matrix/event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["trace_id", "actor", "data"],
      "properties": {
        "type": {
          "const": "com.notyet.agent.incident.created"
        },
        "subject": {
          "type": "string",
          "pattern": "^incident_[A-Za-z0-9_-]+$"
        },
        "trace_id": {
          "type": "string",
          "pattern": "^trace_[A-Za-z0-9_-]+$"
        },
        "actor": {
          "type": "object",
          "properties": {
            "type": {
              "const": "system"
            }
          }
        },
        "data": {
          "type": "object",
          "required": ["incident_id", "severity", "category", "summary"],
          "properties": {
            "incident_id": {
              "type": "string",
              "pattern": "^incident_[A-Za-z0-9_-]+$"
            },
            "severity": {
              "type": "string",
              "enum": ["warning", "error", "critical"]
            },
            "category": {
              "type": "string",
              "minLength": 1
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "task_id": {
              "type": "string",
              "pattern": "^task_[A-Za-z0-9_-]+$"
            },
            "related_event_id": {
              "type": "string",
              "minLength": 1
            },
            "related_event_type": {
              "type": "string",
              "pattern": "^com\\.notyet\\.agent\\.[a-z0-9]+(\\.[a-z0-9]+)*$"
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
