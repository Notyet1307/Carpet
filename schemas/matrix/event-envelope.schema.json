{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/matrix/event-envelope.schema.json",
  "title": "Matrix Runtime Event Envelope",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "workspace_id",
    "trace_id",
    "actor",
    "created_at",
    "idempotency_key",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "pattern": "^com\\.notyet\\.agent\\.[a-z0-9]+(\\.[a-z0-9]+)*$"
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "workspace_id": {
      "type": "string",
      "pattern": "^ws_[A-Za-z0-9_-]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9_-]+$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[A-Za-z0-9_-]+$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace_[A-Za-z0-9_-]+$"
    },
    "actor": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["human", "runtime", "worker", "verifier", "system"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "data": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
