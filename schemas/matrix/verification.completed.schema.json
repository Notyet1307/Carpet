{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/matrix/verification.completed.schema.json",
  "title": "Matrix Verification Completed Event",
  "allOf": [
    {
      "$ref": "https://notyet.dev/schemas/matrix/event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["task_id", "run_id", "trace_id", "actor", "data"],
      "properties": {
        "type": {
          "const": "com.notyet.agent.verification.completed"
        },
        "subject": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "task_id": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "run_id": {
          "type": "string",
          "pattern": "^run_[A-Za-z0-9_-]+$"
        },
        "trace_id": {
          "type": "string",
          "pattern": "^trace_[A-Za-z0-9_-]+$"
        },
        "actor": {
          "type": "object",
          "properties": {
            "type": {
              "const": "verifier"
            }
          }
        },
        "data": {
          "type": "object",
          "required": ["verifier_id", "artifact_id", "result", "summary"],
          "properties": {
            "verifier_id": {
              "type": "string",
              "pattern": "^verifier_[A-Za-z0-9_-]+$"
            },
            "artifact_id": {
              "type": "string",
              "pattern": "^artifact_[A-Za-z0-9_-]+$"
            },
            "result": {
              "type": "string",
              "enum": ["passed", "failed"]
            },
            "summary": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
