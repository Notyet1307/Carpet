{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/matrix/task.created.schema.json",
  "title": "Matrix Task Created Event",
  "allOf": [
    {
      "$ref": "https://notyet.dev/schemas/matrix/event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["task_id", "data"],
      "properties": {
        "type": {
          "const": "com.notyet.agent.task.created"
        },
        "subject": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "task_id": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "actor": {
          "type": "object",
          "properties": {
            "type": {
              "const": "human"
            }
          }
        },
        "data": {
          "type": "object",
          "required": [
            "goal",
            "context",
            "scope",
            "acceptance_criteria",
            "proof_requirements",
            "risk"
          ],
          "properties": {
            "goal": {
              "type": "string",
              "minLength": 1
            },
            "context": {
              "type": "string",
              "minLength": 1
            },
            "scope": {
              "type": "object",
              "required": ["allowed_paths", "forbidden_paths"],
              "properties": {
                "allowed_paths": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "forbidden_paths": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": false
            },
            "acceptance_criteria": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "proof_requirements": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "risk": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "requested_capability": {
              "type": "string",
              "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)*$"
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
