{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/matrix/approval.denied.schema.json",
  "title": "Matrix Approval Denied Event",
  "allOf": [
    {
      "$ref": "https://notyet.dev/schemas/matrix/event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["task_id", "trace_id", "actor", "data"],
      "properties": {
        "type": {
          "const": "com.notyet.agent.approval.denied"
        },
        "subject": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "task_id": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "trace_id": {
          "type": "string",
          "pattern": "^trace_[A-Za-z0-9_-]+$"
        },
        "actor": {
          "type": "object",
          "properties": {
            "type": {
              "const": "human"
            }
          }
        },
        "data": {
          "type": "object",
          "required": ["approval_id", "action", "proof_id", "reason"],
          "properties": {
            "approval_id": {
              "type": "string",
              "pattern": "^approval_[A-Za-z0-9_-]+$"
            },
            "action": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$",
              "not": {
                "pattern": "^(task|all|everything)\\."
              }
            },
            "proof_id": {
              "type": "string",
              "pattern": "^proof_[A-Za-z0-9_-]+$"
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
