{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/matrix/task.accepted.schema.json",
  "title": "Matrix Task Accepted Event",
  "allOf": [
    {
      "$ref": "https://notyet.dev/schemas/matrix/event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["task_id", "data"],
      "properties": {
        "type": {
          "const": "com.notyet.agent.task.accepted"
        },
        "subject": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "task_id": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "actor": {
          "type": "object",
          "properties": {
            "type": {
              "const": "runtime"
            }
          }
        },
        "data": {
          "type": "object",
          "additionalProperties": false
        }
      }
    }
  ]
}
