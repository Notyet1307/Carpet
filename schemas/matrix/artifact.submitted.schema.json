{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/matrix/artifact.submitted.schema.json",
  "title": "Matrix Artifact Submitted Event",
  "allOf": [
    {
      "$ref": "https://notyet.dev/schemas/matrix/event-envelope.schema.json"
    },
    {
      "type": "object",
      "required": ["task_id", "run_id", "trace_id", "actor", "data"],
      "properties": {
        "type": {
          "const": "com.notyet.agent.artifact.submitted"
        },
        "subject": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "task_id": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "run_id": {
          "type": "string",
          "pattern": "^run_[A-Za-z0-9_-]+$"
        },
        "trace_id": {
          "type": "string",
          "pattern": "^trace_[A-Za-z0-9_-]+$"
        },
        "actor": {
          "type": "object",
          "properties": {
            "type": {
              "const": "worker"
            }
          }
        },
        "data": {
          "type": "object",
          "required": [
            "worker_id",
            "artifact_id",
            "artifact_type",
            "artifact_ref",
            "artifact_sha256"
          ],
          "properties": {
            "worker_id": {
              "type": "string",
              "pattern": "^worker_[A-Za-z0-9_-]+$"
            },
            "artifact_id": {
              "type": "string",
              "pattern": "^artifact_[A-Za-z0-9_-]+$"
            },
            "artifact_type": {
              "type": "string",
              "enum": ["patch", "report", "log", "schema", "fixture"]
            },
            "artifact_ref": {
              "type": "string",
              "format": "uri"
            },
            "artifact_sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "summary": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
