{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/codex/repo-patch-result.schema.json",
  "title": "Codex Repo Patch Result",
  "type": "object",
  "required": [
    "summary",
    "files_changed",
    "tests_added_or_updated",
    "validation_results",
    "risk_notes",
    "rollback_notes",
    "follow_up_tasks"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "action"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "enum": ["added", "modified", "deleted", "renamed"]
          }
        },
        "additionalProperties": false
      }
    },
    "tests_added_or_updated": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command", "exit_code", "summary"],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "exit_code": {
            "type": "integer",
            "minimum": 0
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "follow_up_tasks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
