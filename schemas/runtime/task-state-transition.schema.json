  "definitions": {
    "state": {
      "type": "string",
      "enum": [
        "created",
        "accepted",
        "scoped",
        "graph_compiled",
        "capability_selected",
        "work_cell_created",
        "worker_dispatched",
        "running",
        "artifact_submitted",
        "proof_submitted",
        "verifying",
        "waiting_approval",
        "approved",
        "pr_created",
        "completed",
        "rejected",
        "blocked",
        "needs_human_input",
        "policy_denied",
        "worker_failed",
        "verification_failed",
        "approval_denied",
        "cancelled"
      ]
    },
    "artifact_ref": {
      "type": "string",
      "pattern": "^artifact_[A-Za-z0-9_-]+$"
    },
    "proof_ref": {
      "type": "string",
      "pattern": "^proof_[A-Za-z0-9_-]+$"
    },
    "approval_ref": {
      "type": "string",
      "pattern": "^approval_[A-Za-z0-9_-]+$"
    },
    "optional_artifact_ref": {
      "anyOf": [
        { "$ref": "#/definitions/artifact_ref" },
        { "type": "null" }
      ]
    },
    "optional_proof_ref": {
      "anyOf": [
        { "$ref": "#/definitions/proof_ref" },
        { "type": "null" }
      ]
    },
    "optional_approval_ref": {
      "anyOf": [
        { "$ref": "#/definitions/approval_ref" },
        { "type": "null" }
      ]
    },
    "base_transition": {
      "type": "object",
      "required": [
        "transition_id",
        "task_id",
        "from",
        "to",
        "trigger_event",
        "actor",
        "requirements",
        "audit_event"
      ],
      "properties": {
        "transition_id": {
          "type": "string",
          "pattern": "^transition_[A-Za-z0-9_-]+$"
        },
        "task_id": {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        "from": {
          "$ref": "#/definitions/state"
        },
        "to": {
          "$ref": "#/definitions/state"
        },
        "trigger_event": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
        },
        "actor": {
          "type": "object",
          "required": ["type", "id"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["human", "runtime", "worker", "verifier"]
            },
            "id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "requirements": {
          "type": "object",
          "required": ["artifact_ref", "proof_ref", "approval_ref"],
          "properties": {
            "artifact_ref": {
              "$ref": "#/definitions/optional_artifact_ref"
            },
            "proof_ref": {
              "$ref": "#/definitions/optional_proof_ref"
            },
            "approval_ref": {
              "$ref": "#/definitions/optional_approval_ref"
            }
          },
          "additionalProperties": false
        },
        "audit_event": {
          "type": "object",
          "required": ["type", "event_id", "trace_id"],
          "properties": {
            "type": {
              "type": "string",
              "pattern": "^task\\.transition\\.[a-z_]+$"
            },
            "event_id": {
              "type": "string",
              "pattern": "^event_[A-Za-z0-9_-]+$"
            },
            "trace_id": {
              "type": "string",
              "pattern": "^trace_[A-Za-z0-9_-]+$"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
