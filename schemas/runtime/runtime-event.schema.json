{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/runtime/runtime-event.schema.json",
  "title": "Runtime Event",
  "type": "object",
  "required": [
    "runtime_event_id",
    "event_type",
    "source_component",
    "source_of_truth",
    "workspace_id",
    "task_id",
    "trace_id",
    "idempotency_key",
    "actor",
    "matrix",
    "validation",
    "enqueue",
    "data"
  ],
  "properties": {
    "runtime_event_id": {
      "type": "string",
      "pattern": "^rtevt_[A-Za-z0-9_-]+$"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "runtime.intent.received",
        "runtime.intake.rejected",
        "runtime.incident.created",
        "runtime.projection.requested"
      ]
    },
    "source_component": {
      "const": "matrix_appservice_gateway"
    },
    "source_of_truth": {
      "const": "runtime"
    },
    "workspace_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^ws_[A-Za-z0-9_-]+$"
        },
        {
          "type": "null"
        }
      ]
    },
    "task_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^task_[A-Za-z0-9_-]+$"
        },
        {
          "type": "null"
        }
      ]
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace_[A-Za-z0-9_-]+$"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "required": ["type", "id", "derived_from", "claimed_actor"],
      "properties": {
        "type": {
          "const": "matrix_user"
        },
        "id": {
          "type": "string",
          "pattern": "^@[^:]+:[A-Za-z0-9.-]+$"
        },
        "derived_from": {
          "const": "matrix.sender"
        },
        "claimed_actor": {
          "anyOf": [
            {
              "type": "object",
              "required": ["type", "id"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["human", "runtime", "worker", "verifier", "system"]
                },
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "display_name": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "matrix": {
      "type": "object",
      "required": [
        "transaction_id",
        "event_id",
        "room_id",
        "sender",
        "event_type",
        "claimed_actor",
        "room_mapping"
      ],
      "properties": {
        "transaction_id": {
          "type": "string",
          "minLength": 1
        },
        "event_id": {
          "type": "string",
          "pattern": "^\\$[A-Za-z0-9_.=-]+$"
        },
        "room_id": {
          "type": "string",
          "pattern": "^![A-Za-z0-9_.=-]+:[A-Za-z0-9.-]+$"
        },
        "sender": {
          "type": "string",
          "pattern": "^@[^:]+:[A-Za-z0-9.-]+$"
        },
        "event_type": {
          "type": "string",
          "pattern": "^com\\.notyet\\.agent\\.[a-z0-9]+(\\.[a-z0-9]+)*$"
        },
        "claimed_actor": {
          "anyOf": [
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ]
        },
        "room_mapping": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["mapped", "unknown_room", "unknown_workspace"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["status", "schema_id", "errors"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["accepted", "rejected"]
        },
        "schema_id": {
          "anyOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "enqueue": {
      "type": "object",
      "required": ["status", "target"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["queued", "not_queued", "retryable_failure"]
        },
        "target": {
          "type": "string",
          "enum": ["runtime_intake", "runtime_incident", "none"]
        }
      },
      "additionalProperties": false
    },
    "data": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
