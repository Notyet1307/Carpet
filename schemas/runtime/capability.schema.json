{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/runtime/capability.schema.json",
  "title": "Runtime Capability Registry",
  "type": "object",
  "required": ["schema_version", "capabilities"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "source_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/capability"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "capability_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)*$"
    },
    "task_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "schema_contract": {
      "type": "object",
      "required": ["schema_ref", "required_fields"],
      "properties": {
        "schema_ref": {
          "type": "string",
          "pattern": "^schema://runtime/capabilities/[a-z0-9.-]+\\.(input|output)@v[0-9]+$"
        },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][A-Za-z0-9_.-]*$"
          }
        }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "required": ["allow", "deny"],
      "properties": {
        "allow": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z]+:[a-z0-9_.*-]+$"
          }
        },
        "deny": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z]+:[a-z0-9_.*-]+$"
          }
        }
      },
      "additionalProperties": false
    },
    "verifier": {
      "type": "object",
      "required": ["capability_ref", "required_evidence"],
      "properties": {
        "capability_ref": {
          "$ref": "#/definitions/capability_id"
        },
        "required_evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      },
      "additionalProperties": false
    },
    "human_gate": {
      "type": "object",
      "required": ["required", "gate_type", "scope"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "gate_type": {
          "type": "string",
          "enum": [
            "none",
            "before_external_action",
            "before_memory_proposal",
            "before_handoff"
          ]
        },
        "scope": {
          "type": "string",
          "enum": ["none", "action_scoped", "proposal_scoped", "review_scoped"]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "required": { "const": false }
            }
          },
          "then": {
            "properties": {
              "gate_type": { "const": "none" },
              "scope": { "const": "none" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "required": { "const": true }
            }
          },
          "then": {
            "properties": {
              "gate_type": {
                "enum": [
                  "before_external_action",
                  "before_memory_proposal",
                  "before_handoff"
                ]
              },
              "scope": {
                "enum": ["action_scoped", "proposal_scoped", "review_scoped"]
              }
            }
          }
        }
      ]
    },
    "execution": {
      "type": "object",
      "required": [
        "requires_isolated_worktree",
        "worktree_created_by",
        "codex_cwd",
        "allow_main_checkout_edits"
      ],
      "properties": {
        "requires_isolated_worktree": {
          "type": "boolean"
        },
        "worktree_created_by": {
          "type": "string",
          "enum": ["runtime", "human"]
        },
        "codex_cwd": {
          "const": "worktree_path"
        },
        "allow_main_checkout_edits": {
          "type": "boolean"
        },
        "cleanup_policy": {
          "type": "string",
          "enum": ["keep_until_merged_or_failed_reviewed"]
        }
      },
      "additionalProperties": false
    },
    "example": {
      "type": "object",
      "required": ["task_type", "route_when"],
      "properties": {
        "task_type": {
          "$ref": "#/definitions/task_type"
        },
        "route_when": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "capability": {
      "type": "object",
      "required": [
        "id",
        "display_name",
        "description",
        "task_types",
        "input_schema",
        "output_schema",
        "worker_type",
        "permissions",
        "proof_required",
        "verifier",
        "human_gate",
        "risk_level",
        "policy_ref",
        "examples"
      ],
      "properties": {
        "id": {
          "$ref": "#/definitions/capability_id"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "task_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/definitions/task_type"
          }
        },
        "input_schema": {
          "$ref": "#/definitions/schema_contract"
        },
        "output_schema": {
          "$ref": "#/definitions/schema_contract"
        },
        "worker_type": {
          "type": "string",
          "enum": [
            "runtime",
            "codex_exec",
            "test_runner",
            "verifier",
            "memory_curator",
            "security_scanner",
            "release_writer",
            "external_action"
          ]
        },
        "permissions": {
          "$ref": "#/definitions/permissions"
        },
        "proof_required": {
          "type": "boolean"
        },
        "verifier": {
          "$ref": "#/definitions/verifier"
        },
        "human_gate": {
          "$ref": "#/definitions/human_gate"
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "policy_ref": {
          "type": "string",
          "pattern": "^capability\\.[a-z0-9]+(\\.[a-z0-9]+)*\\.default$"
        },
        "execution": {
          "$ref": "#/definitions/execution"
        },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/example"
          }
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "worker_type": { "const": "codex_exec" }
            }
          },
          "then": {
            "required": ["execution"],
            "properties": {
              "execution": {
                "type": "object",
                "properties": {
                  "requires_isolated_worktree": { "const": true },
                  "worktree_created_by": { "const": "runtime" },
                  "codex_cwd": { "const": "worktree_path" },
                  "allow_main_checkout_edits": { "const": false }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "risk_level": { "const": "high" }
            }
          },
          "then": {
            "properties": {
              "proof_required": { "const": true },
              "human_gate": {
                "type": "object",
                "properties": {
                  "required": { "const": true }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "worker_type": { "const": "external_action" }
            }
          },
          "then": {
            "properties": {
              "proof_required": { "const": true },
              "human_gate": {
                "type": "object",
                "properties": {
                  "required": { "const": true }
                }
              }
            }
          }
        }
      ]
    }
  }
}
