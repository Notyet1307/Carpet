{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/runtime/task-graph.schema.json",
  "title": "Runtime Task Graph",
  "type": "object",
  "required": ["task_id", "graph_id", "version", "state_source", "nodes", "edges"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9_-]+$"
    },
    "graph_id": {
      "type": "string",
      "pattern": "^graph_[A-Za-z0-9_-]+$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "state_source": {
      "const": "runtime"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/edge"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "node_id": {
      "type": "string",
      "pattern": "^node_[A-Za-z0-9_-]+$"
    },
    "symbol_list": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$"
      },
      "uniqueItems": true
    },
    "capability_ref": {
      "type": "string",
      "pattern": "^capability\\.[a-z0-9_.-]+@v[0-9]+$"
    },
    "event_ref": {
      "type": "string",
      "pattern": "^event_[A-Za-z0-9_-]+$"
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "required_inputs",
        "produces",
        "proof_required",
        "approval_required"
      ],
      "properties": {
        "id": {
          "$ref": "#/definitions/node_id"
        },
        "kind": {
          "type": "string",
          "enum": [
            "event_ingest",
            "runtime_decision",
            "capability_execution",
            "proof_verification",
            "approval_gate",
            "external_action",
            "matrix_projection"
          ]
        },
        "capability_ref": {
          "$ref": "#/definitions/capability_ref"
        },
        "event_ref": {
          "$ref": "#/definitions/event_ref"
        },
        "action_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
        },
        "risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "required_inputs": {
          "$ref": "#/definitions/symbol_list"
        },
        "produces": {
          "$ref": "#/definitions/symbol_list"
        },
        "proof_required": {
          "type": "boolean"
        },
        "approval_required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": {
              "kind": { "enum": ["event_ingest", "matrix_projection"] }
            }
          },
          "then": {
            "type": "object",
            "required": ["event_ref"],
            "properties": {
              "event_ref": {
                "$ref": "#/definitions/event_ref"
              },
              "capability_ref": false
            }
          }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "kind": { "enum": ["capability_execution", "proof_verification"] }
            }
          },
          "then": {
            "type": "object",
            "required": ["capability_ref"],
            "properties": {
              "capability_ref": {
                "$ref": "#/definitions/capability_ref"
              },
              "event_ref": false
            }
          }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "kind": { "enum": ["runtime_decision", "approval_gate"] }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "capability_ref": false,
              "event_ref": false,
              "action_type": false,
              "risk": false
            }
          }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "kind": { "const": "approval_gate" }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "approval_required": { "const": true }
            }
          }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "kind": { "const": "external_action" }
            }
          },
          "then": {
            "type": "object",
            "required": ["capability_ref", "action_type", "risk"],
            "properties": {
              "capability_ref": {
                "$ref": "#/definitions/capability_ref"
              },
              "action_type": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
              },
              "risk": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "event_ref": false
            }
          }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "kind": { "const": "external_action" },
              "risk": { "const": "high" }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "approval_required": { "const": true }
            }
          }
        }
      ]
    },
    "edge": {
      "type": "object",
      "required": ["from", "to", "condition"],
      "properties": {
        "from": {
          "$ref": "#/definitions/node_id"
        },
        "to": {
          "$ref": "#/definitions/node_id"
        },
        "condition": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
        }
      },
      "additionalProperties": false
    }
  }
}
