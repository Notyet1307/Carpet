{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://notyet.dev/schemas/proof/proof-ledger-entry.schema.json",
  "title": "Proof Ledger Entry",
  "type": "object",
  "required": [
    "proof_id",
    "task_id",
    "run_id",
    "trace_id",
    "created_at",
    "capability",
    "summary",
    "artifacts",
    "validation",
    "risk_notes",
    "rollback_notes"
  ],
  "properties": {
    "proof_id": {
      "type": "string",
      "pattern": "^proof_[A-Za-z0-9_-]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9_-]+$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[A-Za-z0-9_-]+$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace_[A-Za-z0-9_-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "capability": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)*$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "uri", "sha256"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["patch", "log", "report", "schema", "fixture"]
          },
          "uri": {
            "type": "string",
            "format": "uri"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    },
    "validation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["command", "exit_code", "status"],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "exit_code": {
            "type": "integer",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped"]
          },
          "log_ref": {
            "type": "string",
            "format": "uri"
          }
        },
        "additionalProperties": false
      }
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
